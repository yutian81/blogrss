name: Upstream Sync

permissions:
  contents: write
  actions: write
  pull-requests: write

on:
  schedule:
    - cron: "0 0 * * *"
  workflow_dispatch:

jobs:
  sync_from_upstream:
    runs-on: ubuntu-latest
    if: ${{ github.event.repository.fork }}

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.SYNC_PAT_TOKEN }}

      - name: Configure Git
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"

      - name: Sync upstream safely
        run: |
          cp conf.yaml conf.yaml.tmp
          
          git remote add upstream https://github.com/willow-god/Friend-Circle-Lite.git
          git fetch upstream
          git merge upstream/main --no-commit --no-ff
          
          cp conf.yaml.tmp conf.yaml
          rm -f conf.yaml.tmp
          
          # 提交变更（有变更才提交，无变更则输出提示）
          git add .
          if git diff --staged --quiet; then
            echo "✅ 当前代码已是最新，无需同步！"
          else
            git commit -m "Sync from upstream $(date '+%Y-%m-%d')"
            git push origin main
            echo "✅ 同步上游更新成功！"
          fi
